/target
/node_modules
*.node
# Per-platform packages are regenerated from package.json in CI (napi create-npm-dirs),
# so the version lives only in the root package.json.
/npm
# index.js (loader) and index.d.ts (types) are generated by `napi build`; the publish
# job rebuilds them on Linux before packing, so they are not committed.
/index.js
/index.d.ts
__test__/*.xlsx
examples/*.xlsx
